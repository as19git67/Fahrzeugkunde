# Datenbank-Pfad (Standard: ./data/fahrzeugkunde.db)
DATABASE_PATH=./data/fahrzeugkunde.db

# E-Mail (SMTP) Konfiguration
# Falls SMTP_HOST nicht gesetzt oder 'localhost' ist, werden Mails nur in der Konsole geloggt.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fahrzeugkunde.local
